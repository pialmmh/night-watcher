<!-- Fail2Ban log decoder for Wazuh -->
<!-- Uses PCRE2 regex via type attribute (Wazuh 4.x+) -->
<decoder name="fail2ban">
  <prematch>fail2ban</prematch>
</decoder>

<decoder name="fail2ban-action">
  <parent>fail2ban</parent>
  <prematch>\.actions</prematch>
  <regex type="pcre2" offset="after_prematch">\S+\s+(\S+)\s+\[(\S+)\]\s+(Ban|Unban)\s+(\S+)</regex>
  <order>log_level, jail_name, action, srcip</order>
</decoder>

<decoder name="fail2ban-found">
  <parent>fail2ban</parent>
  <prematch>\.filter</prematch>
  <regex type="pcre2" offset="after_prematch">\S+\s+(\S+)\s+\[(\S+)\]\s+Found\s+(\S+)</regex>
  <order>log_level, jail_name, srcip</order>
</decoder>
