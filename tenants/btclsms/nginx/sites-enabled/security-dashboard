server {
    listen 7100 ssl;
    server_name _;

    ssl_certificate /etc/nginx/ssl/STAR.btcliptelephony.gov.bd.crt;
    ssl_certificate_key /etc/nginx/ssl/STAR.btcliptelephony.gov.bd_key.key;

    root /var/www/security-dashboard;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy to OpenSearch (server-side auth — no credentials in browser)
    location /api/es/ {
        proxy_pass https://127.0.0.1:9200/;
        proxy_ssl_verify off;
        proxy_set_header Authorization "Basic YWRtaW46YWRtaW4=";
        proxy_set_header Content-Type "application/json";
        proxy_hide_header Authorization;
    }

    # Proxy to Wazuh API
    location /api/wazuh/ {
        proxy_pass https://127.0.0.1:55000/;
        proxy_ssl_verify off;
    }

    # Cache static assets
    location ~* \.(js|css|png|svg|ico|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
