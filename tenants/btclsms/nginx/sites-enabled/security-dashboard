# Security Dashboard - Night-Watcher
# Serves React SPA + proxies API calls to backend services

server {
    listen 7100;
    server_name _;

    root /var/www/security-dashboard;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy to OpenSearch (server-side auth — no credentials in browser)
    location /api/es/ {
        proxy_pass https://127.0.0.1:9200/;
        proxy_ssl_verify off;
        proxy_set_header Authorization "Basic YWRtaW46YWRtaW4=";
        proxy_set_header Content-Type "application/json";
        proxy_hide_header Authorization;
    }

    # Proxy to Wazuh API
    location /api/wazuh/ {
        proxy_pass https://127.0.0.1:55000/;
        proxy_ssl_verify off;
    }

    # Proxy to module status API (supervisord status, fail2ban, crowdsec, etc.)
    location /api/status/ {
        proxy_pass http://127.0.0.1:7101/;
    }

    # Proxy to HA Controller status API (per-node)
    location /api/hactl/ {
        proxy_pass http://127.0.0.1:7102/;
    }

    # Cache static assets
    location ~* \.(js|css|png|svg|ico|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
